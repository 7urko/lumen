# Base Sepolia RPC the bundler talks to (your own node later; public for now).
RPC_URL=https://sepolia.base.org

# A FUNDED relay key the bundler uses to submit UserOperations and pay gas.
# Generate one with:  node bundler/gen-key.mjs   (run from the repo root)
# Then fund the printed ADDRESS with Base Sepolia test ETH from a faucet.
RELAY_PRIVATE_KEY=0xREPLACE_WITH_FUNDED_RELAY_PRIVATE_KEY

# EntryPoint v0.6 (Coinbase Smart Wallet). Don't change unless you know why.
ENTRYPOINTS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789

# Port the bundler listens on (kept off 3000 so it doesn't clash with `next dev`).
PORT=4337
