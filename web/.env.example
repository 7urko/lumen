# Lumen web app — environment variables. Copy to .env.local (gitignored) and fill in.
# EVERY var is optional; sensible public defaults are built in. NEXT_PUBLIC_* are exposed
# to the browser by design (they're public endpoints, not secrets).

# ── The mainnet/testnet switch ────────────────────────────────────────────────
# Unset or anything other than "base" = Base Sepolia testnet (safe default).
# Set to "base" ONLY when build is green, bundler is running, and legal is in place.
# NEXT_PUBLIC_CHAIN=base

# ── RPC endpoints (use your own nodes in production for reliability + privacy) ──
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
# NEXT_PUBLIC_MAINNET_RPC=https://ethereum-rpc.publicnode.com   # Ethereum L1: ENS + net-worth reads

# ── ERC-4337 bundler (REQUIRED for smart-account sends) ───────────────────────
# A bundler endpoint (self-hosted Alto, or a provider like Pimlico). It only relays
# already-signed transactions — it can't access funds, so this stays non-custodial.
# NEXT_PUBLIC_BUNDLER_URL=https://api.pimlico.io/v2/84532/rpc?apikey=YOUR_KEY

# ── Gas sponsorship / gasless (optional) ──────────────────────────────────────
# Set a Pimlico sponsorship-policy id to make sends gasless (account needs no ETH).
# PAYMASTER_URL defaults to the bundler URL (Pimlico serves both on one endpoint).
# NEXT_PUBLIC_PAYMASTER_POLICY=sp_your_policy_id
# NEXT_PUBLIC_PAYMASTER_URL=https://api.pimlico.io/v2/84532/rpc?apikey=YOUR_KEY

# ── Sanctions geo-block (server-side; on by default) ──────────────────────────
# Set to "off" to disable (e.g. local testing). See middleware.ts for the blocked list.
# GEOBLOCK=off
