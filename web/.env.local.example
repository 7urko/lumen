# Copy to web/.env.local and restart `npm run dev -w web`.

# Self-hosted ERC-4337 bundler URL (see ../bundler/README.md).
# When set, /smart-account can send real gasless UserOperations.
NEXT_PUBLIC_BUNDLER_URL=http://localhost:4337

# Optional: point the chain layer at your own node instead of the public RPC.
# NEXT_PUBLIC_BASE_RPC=https://mainnet.base.org
# NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org
